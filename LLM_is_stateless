from dotenv import load_dotenv
# dotenv는 라이브러리(다른 사람이 미리 만들어 놓은 기능 모음)
# .env 파일에 저장된 환경 변수(Environment Variable)를 읽어오는 라이브러리

from anthropic import Anthropic
# 회사에서 만든 Python 라이브러리를 설치
# Anthropic은 함수가 아니라 클래스(Class)


load_dotenv()
# .env 파일의 내용을 프로그램이 사용

client = Anthropic()
# Anthropic은 AI 회사 이름
# Anthropic 객체는 Claude API와 통신하는 클라이언트
# 서비스를 요청(Request)하는 프로그램 = Claude와 통신할 객체(Client)를 만드는 것

MODEL = "claude-sonnet-4-6"

# LLM은 기억하지 못한다

# 첫 번째 호출 
# 모델에게 이름을 알린다
response1 = client.messages.create(
    model = MODEL,
    max_tokens=256,
    messages=[
        {"role" : "user", "content": "내 이름은 서연이야. 기억해줘!"}
    ],
)

print(f"[1번 호출] 사용자: 내 이름은 서연이야. 기억해줘!")
print(f"[1번 호출] Claude: {response1.content[0].text}")

# 두 번째 호출 
# 새로운 요청에서 이름을 묻기
response2 = client.messages.create(
    model = MODEL,
    max_tokens = 256,
    messages=[
        {"role": "user", "content": "내 이름이 뭐였지?"}
    ],
)

print(f"\n[2번 호출] 사용자: 내 이름이 뭐였지?")
print(f"[2번 호출] Claude: {response2.content[0].text}")
# 이전 대화이지만 기억하지 못함

# 세 번째 호출
# 이름을 알려주고 물어보기

response3 = client.messages.create(
    model=MODEL,
    max_tokens=1256,
    messages=[
        {"role" : "user", "content": "내 이름은 서연이야. 기억해줘!"},
        {"role": "assistant", "content": response1.content[0].text},
        {"role": "user", "content": "내 이름이 뭐였지? 나는 지금 10살이야. 내가 공부할 방법을 "}
    ],
)

print(f"[히스토리 포함] 사용자: 내 이름이 뭐였지?")
print(f"[히스토리 포함] Claude: {response3.content[0].text}")
