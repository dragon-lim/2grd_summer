# 동기 비동기의 코드를 보고 분석할 수 있어야 한다
# 동기 비동기의 개념을 정확하게 이해해야한다

import time
import asyncio

# 비동기 함수 정의
async def make_order(menu:str, taken_time:int)->str:
    print(f"{menu} 준비중")
    await asyncio.sleep(taken_time)
    # time.sleep(taken_time)
    return print(f"{menu} 준비완료")
    
# 비동기 함수 정의
async def main():
    start = time.time()
    # print(make_order("라떼", 3))
    # print(make_order("아아", 2))
    # print(make_order("우유", 1))

    result1 =  asyncio.create_task(make_order("라떼", 3))
    result2 =  asyncio.create_task(make_order("아아", 2))
    result3 =  asyncio.create_task(make_order("우유", 1))

    # task 객체 생성
    print(result1, result2, result3)
    elasped_time = time.time() - start

    print(f"경과 시간: {elasped_time}")

if __name__ == "__main__":
    asyncio.run(main()) #이벤트 루프 생성


