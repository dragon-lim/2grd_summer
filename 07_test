async def call_llm(client:AsyncAnthropic, prompt:str, max_retries:int=3, delay:int=3, timeout:int=50)->str:
    # 프롬포트 전송
    for attempt in range(max_retries):
        async with sem:
            # 예외처리 하기 ──────────────────────────────────────────
            try:
                # LLM API를 호출할 때, 재전송이 필요한 경우 : 1) 연결 실패(답이 오지않은 경우) 2) 사용자가 원하는 형태의 대답이 아닐 때 (답이 오더라도 재전송 할 수 있다)
                # 재전송 지정은 client = AsyncAnthropic(max_retries=6) / call_llm 의 매개변수로 지정 max_retries:int=3
                # try, except는 basic 으로 스스로 2번 보내게 지정되어 있음
                # for 문이 없어지는건 아님, 답변이 왔지만 재전송 필요한 경우 for문으로 다시 보내야한다 (원하는 포멧으로 답변을 받기 위해서)
                # (ex, 고객의 후기 등을 읽을 때 숫자 int를 원하지만 프롬포트를 무시하고 숫자, 문자 같이 들어온 경우 for문으로 재전송 보내야한다, 리플렉션(그대로 다시 보내는게 아니라 질문등을 재반영해서 다시 전송해야 한다))
                # 기존 규칙기반과는 다른 방식이라 재밌다! ㅋㅋ!
                # 정확한 규칙기반이 아니라면, llm을 도입애햐 한다
                # 소 잡는 칼, 닭 잡는 칼 다르다!

                async with asyncio.timeout(timeout):
                    # 이정도 시간 (여기선 50초) 그 시간이 지났어도 답변이 오지 않으면 task는 죽었다
                    # 만약 주워진 시간에 답변이 오지 않으면 time out 으로 오류해라. / 죽은 task는 버리고 다음 task로 ㄱㄱ
                    # (내부적으로 지원도 있음)

                    rsp = await client.messages.create(
                        model = "claude-haiku-4-5",
                        max_tokens = 200,
                        messages = [{"role":"user", "content": prompt}]
                    )

                    return rsp.content[0].text
            except Exception as e:
                print(f"예외 발생 : {e}")
                # 즉시 예외 발생: 모델명을 잘 못 선택했다 , 잘못된 api key 등등
                
                # 재전송
                # 재전송을 했는데 최대 횟수를 넘어가면 
                # call llm을 호출한 쪽에다가 예외를 던져주면, try catch 해서 처리 해야한다
                # 하지만 여러번 시도를 했지만 답변이 나아지지 않으면 호출한 쪽에서 처리를 해야한다
                if attempt >= max_retries -1:
                    raise Exception

                    # 오류가 생겼을 때 바로 재전송이 아니라 물러난 뒤
                    # 동일하게 다시 뛰어온다면 
                    # random back off를 해야한다 
                await asyncio.sleep(delay)
                

    # LLM 호출 → 결과값 검증 → 반환 (실패 시 재시도)

    # 1) 호출 성공의 경우
